# ─── Required ────────────────────────────────────────────────────────────────
# Supabase project URL (find in Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in client builds)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL — must be HTTPS in production (e.g. on Render or Railway)
# Local dev: http://localhost:5000
# Production: https://your-backend.onrender.com  (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# ─── Optional ────────────────────────────────────────────────────────────────
# Set to 'production' to suppress debug output
VITE_APP_ENV=production
